# ── AI Provider (pick ONE) ──────────────────────────────────
# Options: "groq" (free), "gemini" (free), "ollama" (free/local), "anthropic" (paid)
AI_PROVIDER=groq

# Groq — FREE, fast (get key at https://console.groq.com)
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# Google Gemini — FREE tier (get key at https://aistudio.google.com)
# GEMINI_API_KEY=your-gemini-key-here
# GEMINI_MODEL=gemini-2.5-flash-lite

# Ollama — FREE, runs locally (install from https://ollama.com)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3

# Anthropic — PAID (get key at https://console.anthropic.com)
# ANTHROPIC_API_KEY=your-anthropic-key-here
# ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Notion ──────────────────────────────────────────────────
NOTION_API_TOKEN=your-notion-integration-token-here

# ── Schedule ────────────────────────────────────────────────
SCAN_INTERVAL_HOURS=6
